{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "./Dockerfile"
    },
    "deploy": {
        "numReplicas": 1,
        "startCommand": "/usr/local/bin/railway-cmd.sh",
        "healthcheckPath": "/api/method/ping",
        "healthcheckTimeout": 1200
    }
}